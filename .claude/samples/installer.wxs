<?xml version="1.0" encoding="UTF-8"?>
<!--
  installer.wxs — полный пример WiX XML для создания .msi через wixl (msitools)

  wixl компилирует этот XML в .msi на Linux или macOS:
    wixl -v -o dist/myapp-x64.msi -a x64 \
         -D Version=1.2.3.0 \
         -D Manufacturer="PowerTech Center" \
         -D SourceDir=dist\windows-amd64 \
         installer.wxs

  wixl из пакета msitools НЕ поддерживает:
    - UI диалоги (WixUI)               ← только silent install
    - DLL/COM/managed CustomActions
    - Burn Bootstrapper
    - Merge Modules (.msm)
    - WiX Extensions (IIS, SQL, .NET)
    - MajorUpgrade элемент
    - ServiceInstall / ServiceControl
    - Локализацию (.wxl файлы)

  Для полного WiX Toolset (Windows): использовать wix.exe / candle.exe + light.exe
  Для CI/CD на Linux: wixl достаточен для консольных утилит
-->

<!--
  Переменные препроцессора — переопределяются из CLI через -D VAR=VAL
  Синтаксис: $(var.ИМЯ)
  Также доступны: $(env.ENV_VAR), $(sys.SOURCEFILEDIR)
-->
<?define ProductVersion  = "1.0.0.0" ?>
<?define Manufacturer    = "PowerTech Center" ?>
<?define ProductName     = "MyApp" ?>
<?define UpgradeCode     = "12345678-1234-1234-1234-123456789ABC" ?>
<?define SourceDir       = "dist\windows-amd64" ?>
<?define InstallDirName  = "MyApp" ?>
<?define HelpUrl         = "https://github.com/powertech-center/myapp" ?>
<?define AboutUrl        = "https://powertech.center" ?>

<!--
  Условная компиляция (передать через: wixl -D Platform=x64):
  <?if $(var.Platform) = "x64" ?>
    ... 64-bit логика ...
  <?else ?>
    ... 32-bit логика ...
  <?endif ?>

  Проверка определённости переменной:
  <?ifdef DEBUG ?>
    <Property Id="DEBUGMODE" Value="1" />
  <?endif ?>
  <?ifndef RELEASE ?>
    ...
  <?endifndef ?>

  Include внешнего файла:
  <?include "common\directories.wxi" ?>
-->

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!--
    ═══════════════════════════════════════════════════════════════
    PRODUCT — корневой элемент установщика
    ═══════════════════════════════════════════════════════════════

    Id           → GUID версии продукта. "*" = автогенерация (рекомендуется).
                   Каждая новая версия получает уникальный ProductCode.
                   ProductCode меняется при каждом релизе → позволяет сосуществовать.

    Name         → название в Add/Remove Programs (ARP) и диалогах установщика.

    Language     → LCID: 1033=English, 1049=Russian, 1031=German.
                   Для multi-language пакетов: Language="1033,1049"

    Version      → формат Major.Minor.Build.Revision.
                   ВАЖНО: Windows Installer сравнивает только Major.Minor.Build
                   (1.2.3.0 = 1.2.3.99 при сравнении для обновлений).

    Manufacturer → производитель. Используется как корень пути в реестре.

    UpgradeCode  → GUID линии продукта. НИКОГДА не меняется между версиями!
                   По UpgradeCode Windows Installer находит предыдущую версию.
                   Изменение UpgradeCode = новый продукт, старый не удалится.

    Codepage     → кодовая страница строк в MSI (1252=Latin, 65001=UTF-8).
  -->
  <Product
    Id="*"
    Name="$(var.ProductName)"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="$(var.Manufacturer)"
    UpgradeCode="$(var.UpgradeCode)">

    <!--
      ═══════════════════════════════════════════════════════════════
      PACKAGE — метаданные MSI-файла
      ═══════════════════════════════════════════════════════════════

      InstallerVersion → минимальная версия Windows Installer:
                          100 = 1.0, 200 = 2.0 (XP), 300 = 3.0 (XP SP2),
                          400 = 4.0 (Vista), 450 = 4.5 (Vista SP1), 500 = 5.0 (Win7)
                          Рекомендуется: 500 (Win7+)

      Compressed       → "yes" — встроить все файлы в MSI (единый файл).
                          "no" — файлы в отдельном .cab рядом с MSI.

      InstallScope     → "perMachine" — для всех пользователей (требует Admin).
                          "perUser"   — только для текущего пользователя.

      InstallPrivileges → "elevated" — всегда с правами администратора.
                           "limited"  — без прав администратора (только perUser).

      Platform         → "x86" или "x64". Или задать через wixl -a x64.

      Description      → описание в свойствах MSI файла.

      Comments         → комментарий (SummaryInformation).

      Keywords         → ключевые слова для поиска.

      Languages        → список поддерживаемых языков (LCID через запятую).

      SummaryCodepage  → кодовая страница SummaryInformation (1252 или 65001).

      AdminImage       → "yes" — создать административный образ (для сети).

      ShortNames       → "yes" — использовать 8.3 имена файлов.
    -->
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="$(var.ProductName) $(var.ProductVersion) Installer"
      Manufacturer="$(var.Manufacturer)"
      Keywords="myapp,tool,crossler"
      Comments="Copyright $(var.Manufacturer)"
    />

    <!--
      ═══════════════════════════════════════════════════════════════
      MEDIA — упаковка файлов в CAB-архивы
      ═══════════════════════════════════════════════════════════════

      MediaTemplate — автоматическое управление кабинетами.
        EmbedCab="yes"      → встроить cab в MSI
        CompressionLevel    → none|low|medium|high|mszip (по умолчанию mszip)
        MaximumCabinetSizeForLargeFileSplitting → порог для split (MB)
        MaximumUncompressedMediaSize → макс размер несжатого кабинета

      Альтернатива — явный Media для тонкого контроля:
        <Media Id="1" Cabinet="files.cab" EmbedCab="yes"
               CompressionLevel="high" DiskId="1" LastSequence="100"
               VolumeLabel="Disk1" DiskPrompt="Insert Disk 1"/>
    -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!--
      ═══════════════════════════════════════════════════════════════
      ICON — иконки
      ═══════════════════════════════════════════════════════════════

      Id          → идентификатор, используется в Property и Shortcut.
      SourceFile  → путь к .ico файлу.
    -->
    <Icon Id="ProductIcon" SourceFile="resources\app.ico" />

    <!--
      ═══════════════════════════════════════════════════════════════
      PROPERTY — именованные свойства установщика
      ═══════════════════════════════════════════════════════════════

      Встроенные свойства ARP (Add/Remove Programs):
        ARPPRODUCTICON  → иконка в ARP
        ARPHELPLINK     → URL "Техническая поддержка"
        ARPURLINFOABOUT → URL "Дополнительные сведения"
        ARPCONTACT      → контактная информация
        ARPCOMMENTS     → комментарий
        ARPNOMODIFY     → "1" — скрыть кнопку "Изменить"
        ARPNOREMOVE     → "1" — скрыть кнопку "Удалить" (не рекомендуется)
        ARPNOREPAIR     → "1" — скрыть кнопку "Восстановить"
        ARPINSTALLLOCATION → фактический путь установки (устанавливается скриптом)
        ARPSYSTEMCOMPONENT → "1" — скрыть из ARP (только для компонентов)

      Встроенные свойства установщика:
        ALLUSERS        → "1"=перeMachine, ""=perUser, "2"=оба режима
        REINSTALLMODE   → флаги переустановки (amus = типичный набор)
        WIXUI_INSTALLDIR → ID директории для WixUI диалога выбора пути
        MSIFASTINSTALL  → ускоренная установка (пропустить некоторые проверки)
        ARPSIZE         → размер установки в KB (для ARP)
        TARGETDIR       → корень установки (всегда SourceDir)

      Secure Properties (Restricted по UAC):
        PUBLIC свойства — видны elevated процессам.
        PRIVATE свойства (имя содержит строчные буквы) — не передаются elevated.
    -->
    <Property Id="ARPPRODUCTICON"  Value="ProductIcon" />
    <Property Id="ARPHELPLINK"     Value="$(var.HelpUrl)" />
    <Property Id="ARPURLINFOABOUT" Value="$(var.AboutUrl)" />
    <Property Id="ARPCONTACT"      Value="dev@powertech.center" />
    <Property Id="ARPNOMODIFY"     Value="1" />
    <Property Id="ARPCOMMENTS"     Value="$(var.ProductName) $(var.ProductVersion)" />

    <!-- Пользовательские свойства (Public — заглавные буквы) -->
    <Property Id="INSTALLDIR" Secure="yes" />

    <!--
      ═══════════════════════════════════════════════════════════════
      CONDITION — условия установки
      ═══════════════════════════════════════════════════════════════

      На уровне Product: прерывает установку если условие НЕ выполнено.
      Message → текст ошибки, показываемый пользователю.

      Встроенные свойства для условий (Windows Installer Properties):

      Версия ОС:
        VersionNT     → числовая версия: 501=XP, 600=Vista, 601=Win7,
                         602=Win8, 603=Win8.1, 1000+=Win10/11
        VersionNT64   → то же для 64-bit систем
        Version9X     → для Win9x (устарело)
        MsiNTProductType → 1=Workstation, 2=DC, 3=Server
        MsiNTSuitePersonal → домашняя версия Windows

      Архитектура:
        Intel64       → 64-bit система (x86_64)
        Intel         → 32-bit процессор
        MsiAMD64      → AMD64/x86_64

      Привилегии:
        Privileged    → запущено с правами администратора
        AdminUser     → текущий пользователь — администратор
        ALLUSERS      → режим установки (1=perMachine)

      Состояние:
        Installed     → продукт уже установлен
        REMOVE        → выполняется удаление
        REINSTALL     → выполняется переустановка
        UPGRADINGPRODUCTCODE → выполняется обновление

      Компоненты .NET:
        NETFRAMEWORK45 → .NET Framework 4.5+ установлен (значение = версия)
        MsiNetAssemblySupport → GAC поддержка доступна
    -->

    <!-- Требовать Windows 7 (VersionNT >= 601) или новее -->
    <Condition Message="This application requires Windows 7 or later.">
      <![CDATA[VersionNT >= 601]]>
    </Condition>

    <!-- Требовать права администратора -->
    <Condition Message="Administrator privileges are required to install $(var.ProductName).">
      <![CDATA[Privileged]]>
    </Condition>

    <!--
      ═══════════════════════════════════════════════════════════════
      UPGRADE — обнаружение и удаление предыдущих версий
      ═══════════════════════════════════════════════════════════════

      wixl НЕ поддерживает MajorUpgrade. Для обновлений — ручной Upgrade.

      Upgrade/@Id         → UpgradeCode (тот же что у Product)
      UpgradeVersion      → диапазон версий для поиска

        Minimum           → минимальная версия (включительно)
        Maximum           → максимальная версия
        IncludeMinimum    → включать минимум (yes по умолчанию)
        IncludeMaximum    → включать максимум (no по умолчанию)
        OnlyDetect        → "yes" — только обнаружить, не удалять
        Property          → свойство куда записать найденные ProductCode

      После Upgrade добавить в InstallExecuteSequence:
        <RemoveExistingProducts After="InstallValidate"/>
    -->
    <Upgrade Id="$(var.UpgradeCode)">
      <!-- Найти и удалить все предыдущие версии (0.0.0.0 до текущей) -->
      <UpgradeVersion
        Minimum="0.0.0.0"
        Maximum="$(var.ProductVersion)"
        IncludeMinimum="yes"
        IncludeMaximum="no"
        Property="PREVIOUSVERSIONSINSTALLED"
        OnlyDetect="no"
      />
      <!-- Обнаружить более новые версии (не удалять) -->
      <UpgradeVersion
        Minimum="$(var.ProductVersion)"
        IncludeMinimum="no"
        OnlyDetect="yes"
        Property="NEWERVERSIONINSTALLED"
      />
    </Upgrade>

    <!-- Прервать установку если установлена более новая версия -->
    <Condition Message="A newer version of $(var.ProductName) is already installed.">
      <![CDATA[NOT NEWERVERSIONINSTALLED]]>
    </Condition>

    <!--
      ═══════════════════════════════════════════════════════════════
      DIRECTORY — структура директорий установки
      ═══════════════════════════════════════════════════════════════

      TARGETDIR → обязательный корень (всегда первый Directory).

      Предопределённые ID (не требуют Name):
        TARGETDIR             → корень (SourceDir)
        ProgramFilesFolder    → C:\Program Files (или x86 для 32-bit пакета)
        ProgramFiles64Folder  → C:\Program Files (всегда 64-bit)
        CommonFilesFolder     → C:\Program Files\Common Files
        CommonFiles64Folder   → C:\Program Files\Common Files (64-bit)
        CommonAppDataFolder   → C:\ProgramData
        LocalAppDataFolder    → %LOCALAPPDATA%
        AppDataFolder         → %APPDATA% (Roaming)
        DesktopFolder         → Рабочий стол
        ProgramMenuFolder     → C:\ProgramData\Microsoft\Windows\Start Menu\Programs
        StartupFolder         → Автозагрузка
        SystemFolder          → C:\Windows\System32 (или SysWOW64 для 32-bit)
        System64Folder        → C:\Windows\System32 (всегда 64-bit)
        WindowsFolder         → C:\Windows
        TempFolder            → %TEMP%
        PersonalFolder        → Мои документы
        MyPicturesFolder      → Мои изображения
        FavoritesFolder       → Избранное
        SendToFolder          → Отправить
        FontsFolder           → C:\Windows\Fonts
        NetHoodFolder         → Сетевое окружение
        PrintHoodFolder       → Принтеры
        RecentFolder          → Последние документы
        TemplateFolder        → Шаблоны
        AdminToolsFolder      → Администрирование
        GlobalAssemblyCache   → GAC (.NET)

      Name → имя папки на диске (для пользовательских директорий).
    -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- Папка установки в Program Files (64-bit) -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="$(var.InstallDirName)" />
      </Directory>

      <!-- Рабочий стол (для ярлыка) -->
      <Directory Id="DesktopFolder" />

      <!-- Меню Пуск → подпапка приложения -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="$(var.ProductName)" />
      </Directory>

      <!-- ProgramData для данных приложения -->
      <Directory Id="CommonAppDataFolder">
        <Directory Id="AppDataDir" Name="$(var.InstallDirName)" />
      </Directory>

    </Directory>

    <!--
      ═══════════════════════════════════════════════════════════════
      FEATURE — логические наборы компонентов
      ═══════════════════════════════════════════════════════════════

      Id          → уникальный идентификатор.
      Title       → название для отображения (в UI, если бы был).
      Description → описание фичи.
      Level       → 0=не устанавливать, 1=по умолчанию, 2+=опционально.
      Display     → hidden|collapse|expand — вид в UI дереве.
      AllowAdvertise → "no"|"yes"|"system" — разрешить рекламируемую установку.
      InstallDefault → "local"|"source"|"followParent" — место установки.
      TypicalDefault → "install"|"advertise" — поведение при "Typical Install".
    -->
    <Feature Id="MainFeature" Title="$(var.ProductName)" Level="1"
             Display="expand" AllowAdvertise="no">
      <ComponentRef Id="MainBinary" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="RegistryEntries" />
      <ComponentRef Id="PathEnvironment" />

      <!-- Опциональная фича: ярлыки -->
      <Feature Id="ShortcutsFeature" Title="Desktop and Start Menu Shortcuts"
               Level="1" AllowAdvertise="no">
        <ComponentRef Id="DesktopShortcutComp" />
        <ComponentRef Id="StartMenuShortcutComp" />
      </Feature>

      <!-- Опциональная фича: данные приложения -->
      <Feature Id="AppDataFeature" Title="Application Data Directory"
               Level="1" AllowAdvertise="no">
        <ComponentRef Id="AppDataDirComp" />
      </Feature>
    </Feature>

    <!--
      ═══════════════════════════════════════════════════════════════
      КОМПОНЕНТЫ — атомарные единицы установки
      ═══════════════════════════════════════════════════════════════

      Component → атомарная единица: либо всё установлено, либо ничего.
      Windows Installer отслеживает установку по компонентам.

      Id          → уникальный строковый идентификатор.
      Guid        → GUID компонента.
                    ПРАВИЛА:
                    • Уникален в пределах одного продукта.
                    • Стабилен пока содержимое компонента не изменилось.
                    • При изменении файлов → НОВЫЙ GUID.
                    • Нельзя использовать один GUID в двух разных продуктах.
      Win64       → "yes" для 64-bit компонентов (влияет на раздел реестра).
      Directory   → ID директории установки.
      NeverOverwrite → "yes" — не перезаписывать если уже установлен.
      Permanent   → "yes" — не удалять при удалении пакета (осторожно!).
      Transitive  → "yes" — переоценивать Condition при переустановке.
      KeyPath     → "yes" — этот компонент сам является KeyPath (без File/Registry).
      SharedDllRefCount → "yes" — использовать счётчик ссылок SharedDLL.
    -->

    <!-- ── Основной бинарник ────────────────────────────────────────────── -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainBinary"
                 Guid="AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA"
                 Win64="yes">
        <!--
          File → файл для установки.

          Id         → уникальный идентификатор.
          Source     → путь на машине сборки.
          Name       → имя на целевой машине (если отличается).
          KeyPath    → "yes" — ключ компонента. Ровно один на Component!
                        Windows Installer проверяет наличие KeyPath для
                        определения статуса установленности компонента.
          Vital      → "yes" — прервать установку при ошибке копирования.
          Compressed → "yes"/"no" — переопределить сжатие для этого файла.
          ReadOnly   → "yes" — атрибут только-чтение.
          Hidden     → "yes" — скрытый файл.
          System     → "yes" — системный файл.
          Checksum   → "yes" — включить CRC checksum в MSI (для PE файлов).
          ShortName  → 8.3 имя файла.
          LongName   → длинное имя (устарело, используйте Name).
          DefaultVersion → версия файла по умолчанию (если нет ресурса версии).
          DefaultLanguage → язык файла по умолчанию.
          FontTitle  → заголовок для шрифтов (только для .ttf/.otf).
          TrueType   → "yes" — это TrueType шрифт.
          SelfRegCost → стоимость саморегистрации COM (в байтах).
          Assembly   → ".net"|"win32" — сборка .NET или Win32 для GAC/SxS.
        -->
        <File
          Id="MainExe"
          Source="$(var.SourceDir)\myapp.exe"
          Name="myapp.exe"
          KeyPath="yes"
          Vital="yes"
          Checksum="yes"
        />

        <!-- Дополнительные файлы в том же Component -->
        <File Id="LicenseFile" Source="LICENSE.txt" Vital="no" />
        <File Id="ReadmeFile"  Source="README.txt"  Vital="no" />
      </Component>
    </DirectoryRef>

    <!-- ── Конфигурационный файл ─────────────────────────────────────────── -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="ConfigFile"
                 Guid="BBBBBBBB-BBBB-BBBB-BBBB-BBBBBBBBBBBB"
                 Win64="yes">
        <File
          Id="DefaultConfig"
          Source="config\default.yaml"
          Name="config.yaml"
          KeyPath="yes"
        />
      </Component>
    </DirectoryRef>

    <!-- ── Записи в реестр + PATH ────────────────────────────────────────── -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="RegistryEntries"
                 Guid="CCCCCCCC-CCCC-CCCC-CCCC-CCCCCCCCCCCC"
                 Win64="yes">
        <!--
          RegistryKey → группа записей под одним ключом.

          Root      → HKLM=HKEY_LOCAL_MACHINE, HKCU=HKEY_CURRENT_USER,
                       HKCR=HKEY_CLASSES_ROOT,
                       HKMU=HKCU для perUser / HKLM для perMachine

          Action    → createAndRemoveOnUninstall — создать и удалить при удалении пакета.
                       createKeyAndRemoveKeyOnUninstall — только ключ без значений.
                       create — создать без удаления.
                       none   — не создавать ключ (только значения).

          RegistryValue:
            Type    → string (REG_SZ), integer (REG_DWORD), binary (REG_BINARY),
                       expandable (REG_EXPAND_SZ), multiString (REG_MULTI_SZ)
            KeyPath → "yes" — эта запись является KeyPath компонента
        -->
        <RegistryKey Root="HKLM"
                     Key="Software\PowerTech\MyApp"
                     Action="createAndRemoveOnUninstall">
          <RegistryValue Name="InstallPath" Value="[INSTALLFOLDER]"
                         Type="string" KeyPath="yes" />
          <RegistryValue Name="Version"     Value="$(var.ProductVersion)"
                         Type="string" />
          <RegistryValue Name="Manufacturer" Value="$(var.Manufacturer)"
                         Type="string" />
          <!-- REG_EXPAND_SZ — значение с переменными окружения -->
          <RegistryValue Name="DataPath"
                         Value="%PROGRAMDATA%\$(var.InstallDirName)"
                         Type="expandable" />
          <!-- REG_DWORD -->
          <RegistryValue Name="InstallDate" Value="20240101" Type="integer" />
        </RegistryKey>

        <!-- Дополнительный ключ HKCU -->
        <RegistryKey Root="HKCU"
                     Key="Software\PowerTech\MyApp"
                     Action="createAndRemoveOnUninstall">
          <RegistryValue Name="FirstRun" Value="1" Type="integer" />
        </RegistryKey>
      </Component>
    </DirectoryRef>

    <!-- ── Переменная PATH ────────────────────────────────────────────────── -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="PathEnvironment"
                 Guid="DDDDDDDD-DDDD-DDDD-DDDD-DDDDDDDDDDDD"
                 Win64="yes">
        <!--
          Environment → управление переменными окружения.

          Id        → идентификатор.
          Name      → имя переменной окружения.
          Value     → значение для добавления/задания.
          Action    → set    — задать переменную (заменить существующую).
                       remove — удалить переменную.
                       append — добавить Value в конец (с разделителем).
                       prepend — добавить Value в начало.
          Part      → all   — вся переменная (для set/remove).
                       first — начало переменной (для append/prepend).
                       last  — конец переменной (для append/prepend).
          System    → "yes" = системная, "no" = пользовательская.
          Permanent → "yes" = не удалять при удалении пакета.
          Separator → разделитель для append/prepend (по умолчанию ";").
        -->
        <Environment
          Id="AddToPath"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Action="set"
          Part="last"
          System="yes"
          Permanent="no"
          Separator=";"
        />
        <RegistryValue Root="HKLM"
                       Key="Software\PowerTech\MyApp"
                       Name="PathAdded"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ── Ярлык на рабочем столе ────────────────────────────────────────── -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcutComp"
                 Guid="EEEEEEEE-EEEE-EEEE-EEEE-EEEEEEEEEEEE">
        <!--
          Shortcut → создать ярлык (.lnk).

          Id              → идентификатор.
          Directory       → директория для ярлыка.
          Name            → имя ярлыка (без .lnk).
          Target          → цель: [INSTALLFOLDER] → раскрывается в реальный путь.
          Arguments       → аргументы командной строки.
          Description     → подсказка (tooltip).
          WorkingDirectory → рабочая директория при запуске.
          Icon            → ID иконки из <Icon>.
          IconIndex       → индекс иконки в .ico файле.
          Show            → normal|minimized|maximized — стиль окна при запуске.
          Advertise       → "yes" — рекламируемый ярлык (только WiX/Windows, не wixl).
        -->
        <Shortcut
          Id="DesktopShortcut"
          Directory="DesktopFolder"
          Name="$(var.ProductName)"
          Target="[INSTALLFOLDER]myapp.exe"
          Arguments=""
          Description="Launch $(var.ProductName)"
          WorkingDirectory="INSTALLFOLDER"
          Icon="ProductIcon"
          IconIndex="0"
          Show="normal"
        />
        <!--
          ВАЖНО: компоненты с ярлыками ОБЯЗАТЕЛЬНО должны иметь KeyPath.
          Стандартная практика — RegistryValue как KeyPath.
          Без KeyPath Windows Installer не может отслеживать компонент.
        -->
        <RegistryValue
          Root="HKCU"
          Key="Software\PowerTech\MyApp"
          Name="DesktopShortcut"
          Value="1"
          Type="integer"
          KeyPath="yes"
        />
      </Component>
    </DirectoryRef>

    <!-- ── Ярлык в меню Пуск ─────────────────────────────────────────────── -->
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="StartMenuShortcutComp"
                 Guid="FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF">
        <Shortcut
          Id="StartMenuShortcut"
          Directory="AppMenuFolder"
          Name="$(var.ProductName)"
          Target="[INSTALLFOLDER]myapp.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="ProductIcon"
          IconIndex="0"
        />
        <!--
          RemoveFolder → удалить папку при удалении пакета.
          On → install|uninstall|both
          Обязателен для подпапок меню Пуск — иначе пустая папка остаётся.
        -->
        <RemoveFolder Id="RemoveAppMenuFolder"
                      Directory="AppMenuFolder"
                      On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\PowerTech\MyApp"
          Name="StartMenuShortcut"
          Value="1"
          Type="integer"
          KeyPath="yes"
        />
      </Component>
    </DirectoryRef>

    <!-- ── Директория данных в ProgramData ───────────────────────────────── -->
    <DirectoryRef Id="AppDataDir">
      <Component Id="AppDataDirComp"
                 Guid="11111111-1111-1111-1111-111111111111"
                 Win64="yes">
        <!--
          CreateFolder → создать директорию при установке, удалить при удалении.
          Используется когда Component содержит только директорию, без файлов.
        -->
        <CreateFolder />
        <RegistryValue
          Root="HKLM"
          Key="Software\PowerTech\MyApp"
          Name="DataDir"
          Value="[AppDataDir]"
          Type="string"
          KeyPath="yes"
        />
      </Component>
    </DirectoryRef>

    <!--
      ═══════════════════════════════════════════════════════════════
      CUSTOMACTION — произвольные действия
      ═══════════════════════════════════════════════════════════════

      wixl поддерживает только EXE-based CustomActions (тип 2/18/34/50/82).
      DLL, .NET, VBScript, JavaScript CustomActions НЕ поддерживаются.

      Атрибуты:
        Id          → идентификатор
        Directory   → рабочая директория для ExeCommand
        FileKey     → ID файла (из File) как цель запуска
        Property    → свойство содержащее путь к exe
        ExeCommand  → командная строка (квадратные скобки = директории)
        Return      → check (проверить код, по умолчанию)
                       ignore (игнорировать ошибки)
                       asyncNoWait (запустить асинхронно, не ждать)
                       asyncWait (запустить асинхронно, ждать при завершении)
        Execute     → immediate (немедленно, без rollback)
                       deferred (в транзакции, с rollback)
                       rollback (при откате)
                       commit (при успешной фиксации)
        Impersonate → "no" — выполнять как SYSTEM (только для deferred)
    -->
    <CustomAction
      Id="LaunchAfterInstall"
      Directory="INSTALLFOLDER"
      ExeCommand="[INSTALLFOLDER]myapp.exe --version"
      Return="asyncNoWait"
      Execute="immediate"
    />

    <!--
      ═══════════════════════════════════════════════════════════════
      INSTALLEXECUTESEQUENCE — порядок действий установки
      ═══════════════════════════════════════════════════════════════

      Стандартные точки для вставки (After/Before):
        LaunchConditions      — проверка условий
        FindRelatedProducts   — поиск связанных продуктов (Upgrade)
        ValidateProductID     — проверка PID
        CostInitialize        — инициализация расчёта места
        FileCost              — расчёт места для файлов
        CostFinalize          — завершение расчёта
        InstallValidate       — финальная проверка
        InstallInitialize     — начало установки
        RemoveExistingProducts → здесь удаляются предыдущие версии
        InstallFiles          — копирование файлов
        WriteRegistryValues   — запись реестра
        CreateShortcuts       — создание ярлыков
        WriteEnvironmentStrings → запись переменных окружения
        RegisterUser          — регистрация пользователя
        RegisterProduct       — регистрация продукта
        PublishFeatures       — публикация фич
        PublishProduct        — публикация продукта
        InstallFinalize       — завершение установки
    -->
    <InstallExecuteSequence>
      <!-- Удалить предыдущие версии перед установкой -->
      <RemoveExistingProducts After="InstallValidate" />

      <!-- Запустить приложение после установки (только при первой установке) -->
      <Custom Action="LaunchAfterInstall" After="InstallFinalize">
        <![CDATA[NOT Installed AND NOT REMOVE]]>
      </Custom>
    </InstallExecuteSequence>

    <!--
      INSTALLUISEQUENCE — порядок действий UI части установки.
      Используется только если есть UI диалоги (wixl не поддерживает).

      <InstallUISequence>
        <FindRelatedProducts After="AppSearch" />
      </InstallUISequence>
    -->

  </Product>

  <!--
    ═══════════════════════════════════════════════════════════════
    FRAGMENT — переиспользуемый фрагмент
    ═══════════════════════════════════════════════════════════════

    Fragment может быть в отдельном .wxs файле.
    Компилируется вместе с Product:
      wixl product.wxs fragments.wxs

    ComponentGroup → именованная группа компонентов.
    Ссылка в Feature: <ComponentGroupRef Id="ИМЯ" />

    DirectoryRef → ссылка на Directory из Product (для cross-file ссылок).
  -->
  <Fragment>
    <ComponentGroup Id="ExtraFiles" Directory="INSTALLFOLDER">
      <Component Id="ChangelogFile"
                 Guid="22222222-2222-2222-2222-222222222222">
        <File Id="Changelog"
              Source="CHANGELOG.txt"
              Name="CHANGELOG.txt"
              KeyPath="yes"
              Vital="no" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!--
    ═══════════════════════════════════════════════════════════════
    СПРАВОЧНИК: что поддерживает wixl
    ═══════════════════════════════════════════════════════════════

    ПОДДЕРЖИВАЕТСЯ wixl:
      Product, Package, MediaTemplate, Media
      Directory, DirectoryRef, Component, ComponentGroup, ComponentGroupRef
      Feature, ComponentRef
      File, RemoveFile, RemoveFolder
      Shortcut, Icon, Property
      RegistryKey, RegistryValue
      Condition (на уровне Product и Component)
      Environment
      CreateFolder
      CustomAction (только EXE-based: Directory+ExeCommand, FileKey+ExeCommand)
      InstallExecuteSequence, Custom
      Upgrade, UpgradeVersion, RemoveExistingProducts
      Fragment, ComponentGroup
      Препроцессор: <?define ?>, <?if ?>, <?ifdef ?>, <?include ?>

    НЕ ПОДДЕРЖИВАЕТСЯ wixl:
      WixUI (UI диалоги)                 → только silent install
      DLL/COM/Managed CustomActions      → только EXE-based
      ServiceInstall, ServiceControl     → нет управления Windows Services
      MajorUpgrade                       → используй Upgrade + UpgradeVersion
      Merge, MergeRef (.msm)             → нет Merge Modules
      WiX Extensions (IIS, SQL, .NET)    → нет расширений
      Локализация (.wxl файлы)           → нет полной поддержки
      Burn Bootstrapper (.exe wrapper)   → нет bundle-установщиков
      CloseApplication                   → нет закрытия приложений
      util:InternetShortcut              → нет интернет-ярлыков (WiX extension)
      Advertised Shortcuts               → Shortcut Advertise="yes"
      Binary element                     → нет бинарных данных в MSI
  -->

</Wix>
